{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "bee-module merged values (module.yaml + values-<env>)",
  "description": "helm 에 -f module.yaml -f values-<env>.yaml 로 병합 입력되는 문서의 계약. required 는 최소만 — 필드는 호환되게(additive) 확장된다.",
  "type": "object",
  "required": [
    "metadata",
    "spec",
    "env",
    "namespace"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "spec": {
      "type": "object",
      "description": "image 생략 시 workload 없는 schema-전용 모듈 — Deployment 를 렌더하지 않고 db.migrations 만 소유한다.",
      "required": [
        "chart"
      ],
      "properties": {
        "image": {
          "type": "object",
          "required": [
            "name"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "chart": {
          "type": "object",
          "required": [
            "version"
          ],
          "properties": {
            "version": {
              "type": "string",
              "minLength": 1
            }
          },
          "description": "모듈의 chart 버전 pin. 불일치 시 CLI 가 경고하고 CI lint 가 검증한다."
        },
        "product": {
          "type": "string"
        },
        "dependsOn": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "uses": {
          "type": "object",
          "description": "리소스를 논리 프로파일명으로 참조 → platform 의 `resources` 프로파일에 매칭. 모듈은 배포 위치에 무지하고(구체값은 platform/values 가 가짐), chart 가 룩업·렌더한다.",
          "properties": {
            "compute": { "type": "string", "description": "platform resources.compute 프로파일명(small·…)" },
            "storage": {
              "type": "object",
              "required": ["profile", "mount"],
              "properties": {
                "profile": { "type": "string", "description": "platform resources.storage 프로파일명(persistent·…)" },
                "mount": { "type": "string", "description": "컨테이너 마운트 경로(모듈 지식)" }
              }
            }
          }
        },
        "routing": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "path",
              "port"
            ],
            "properties": {
              "path": {
                "type": "string"
              },
              "port": {
                "type": "integer"
              },
              "auth": {
                "type": "string"
              },
              "rateLimit": {
                "type": "object"
              }
            }
          }
        },
        "secrets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "group",
              "property"
            ],
            "properties": {
              "group": {
                "type": "string"
              },
              "property": {
                "type": "string"
              }
            }
          }
        },
        "db": {
          "type": "object",
          "description": "db 어휘 — target=db 방언(모듈이 선택, 기본값 없음·필수), name=공유 그룹(kind,name), schema=이 모듈이 소유하는 스키마 마커, migrations=SQL 디렉토리, grants=cross-schema 명시 선언.",
          "properties": {
            "target": {
              "type": "string",
              "enum": ["psql", "mysql"],
              "description": "db 방언 — 모듈이 선택한다(자기 SQL 이 방언에 종속되므로). platform provides.db[].target 에 매칭. 기본값 없음 — 미선언 시 실패."
            },
            "name": {
              "type": "string",
              "minLength": 1
            },
            "schema": {
              "type": "string",
              "minLength": 1,
              "description": "이 모듈이 소유(migrations 가 생성)하는 스키마 — cross-schema grant 의 owner 마커. 소유하지 않으면 생략."
            },
            "migrations": {
              "type": "string"
            },
            "grants": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "schema"
                ],
                "properties": {
                  "schema": {
                    "type": "string"
                  },
                  "access": {
                    "type": "string",
                    "enum": [
                      "read"
                    ]
                  }
                }
              }
            }
          },
          "required": [
            "name",
            "target"
          ]
        }
      }
    },
    "namespace": {
      "type": "string",
      "minLength": 1,
      "description": "배치 좌표 — bee 가 platform 의 product→namespace 룩업으로 주입한다. 모듈 파일에 직접 쓰지 않는다."
    },
    "env": {
      "type": "string",
      "minLength": 1
    },
    "registry": {
      "type": "string",
      "minLength": 1
    },
    "imageTag": {
      "type": "string"
    },
    "imageDigest": {
      "type": "string"
    },
    "host": {
      "type": "string",
      "minLength": 1
    },
    "ingressClass": {
      "type": "string"
    },
    "asmPrefix": {
      "type": "string"
    },
    "secretStore": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "dbHost": {
      "type": "string",
      "description": "DB 좌표 — spec.db 선언 시 필요"
    },
    "dbName": {
      "type": "string"
    },
    "dbUser": {
      "type": "string"
    },
    "dbPassword": {
      "type": "string",
      "description": "데모용 — 실환경에서는 External Secrets Operator(ESO) 권장."
    },
    "dbMigrationsHash": {
      "type": "string",
      "description": "마이그레이션 페이로드(SQL+grants) content-hash — bee 가 주입한다. Flyway Job 이름 접미사가 되어 내용 변경 시에만 재실행된다. 모듈 파일에 쓰지 않는다."
    },
    "resources": {
      "type": "object",
      "description": "리소스 프로파일 catalog — platform.yaml 의 spec.resources 를 bee 가 전달한다(values-<env> 로 override 가능). chart 가 spec.uses 로 룩업. compute={profile:{requests,limits}} · storage={profile:{storageClass,size}}.",
      "properties": {
        "compute": { "type": "object" },
        "storage": { "type": "object" }
      }
    }
  }
}
